{
  "id": "code-review",
  "name": "代码审查助手",
  "version": "1.0.0",
  "description": "自动审查代码质量、安全性和最佳实践",
  "author": "AI Agent Team",
  "type": "PROMPT",
  "tags": ["代码生成", "工具调用", "代码审查"],
  "inputs": [
    {
      "name": "code",
      "type": "string",
      "description": "要审查的代码",
      "required": true
    },
    {
      "name": "language",
      "type": "string",
      "description": "编程语言",
      "required": false,
      "defaultValue": "auto"
    }
  ],
  "output": {
    "type": "string",
    "description": "代码审查报告"
  },
  "promptTemplate": "你是一个专业的代码审查专家。请审查以下 {language} 代码，从以下几个方面给出建议：\n\n1. 代码质量\n2. 安全性问题\n3. 性能优化\n4. 最佳实践\n5. 潜在 bug\n\n代码：\n```\n{code}\n```\n\n请给出详细的审查报告。",
  "metadata": {
    "category": "development",
    "license": "MIT",
    "homepage": "https://github.com/aiagent/skill-code-review"
  }
}
